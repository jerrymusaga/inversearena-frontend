# Server
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inversearena?schema=public

# MongoDB
MONGODB_URI=mongodb://localhost:27017/inversearena

# Admin auth
# Must be ≥32 characters (enforced at startup) to resist timing attacks
# ⚠️ Change this from the default value before deploying
ADMIN_API_KEY=change-me-in-production
# Admin confirmation token TTL in seconds. Minimum 300 (5 minutes).
# Set to 0 if you do not use confirmation tokens (API key auth only).
ADMIN_TOKEN_TTL_SECONDS=900

# Wallet auth (JWT)
JWT_SECRET=change-me-minimum-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NONCE_TTL_SECONDS=300

# Soroban / Stellar
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
PAYOUT_CONTRACT_ID=C...
PAYOUT_SOURCE_ACCOUNT=G...
PAYOUT_METHOD_NAME=distribute_winnings

# Oracle webhook
ORACLE_WEBHOOK_SECRET=change-me-in-production

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting (defaults shown)
# RATE_LIMIT_NONCE_PREFIX=rl:auth:nonce
# RATE_LIMIT_NONCE_POINTS=5
# RATE_LIMIT_NONCE_WINDOW_SECONDS=60
# RATE_LIMIT_VERIFY_PREFIX=rl:auth:verify
# RATE_LIMIT_VERIFY_POINTS=10
# RATE_LIMIT_VERIFY_WINDOW_SECONDS=60
# RATE_LIMIT_REFRESH_PREFIX=rl:auth:refresh
# RATE_LIMIT_REFRESH_POINTS=20
# RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
# RATE_LIMIT_POOLS_PREFIX=rl:pools:create
# RATE_LIMIT_POOLS_POINTS=3
# RATE_LIMIT_POOLS_WINDOW_SECONDS=60

# Payout execution flags
PAYOUTS_LIVE_EXECUTION=false
PAYOUTS_SIGN_WITH_HOT_KEY=false

# Optional: only set in controlled environments
# PAYOUT_HOT_SIGNER_SECRET=S...

# Payout worker tuning
PAYOUTS_MAX_GAS_STROOPS=2000000
PAYOUTS_MAX_ATTEMPTS=5
PAYOUTS_CONFIRM_POLL_MS=2500
PAYOUTS_CONFIRM_MAX_POLLS=20
